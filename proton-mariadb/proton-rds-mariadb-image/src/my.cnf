[mysqld]
port = 3306
user = mysql
bind_address = 0.0.0.0
datadir = /var/lib/mysql
pid_file = /var/lib/mysql/mysql.pid

#Character Sets and Collations
character_set_server = utf8mb4
collation_server = utf8mb4_unicode_ci
init_connect = 'SET NAMES utf8mb4'

# Normal
skip_name_resolve = 1
max_connections = 10000
max_connect_errors = 10000
table_definition_cache = 2000
table_open_cache = 2000
table_open_cache_instances = 8
open_files_limit = 65535
transaction_isolation = READ-COMMITTED
thread_stack = 512K
group_concat_max_len = 1048576
max_allowed_packet = 1G
sql_mode = ONLY_FULL_GROUP_BY,STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION
lower_case_table_names = 1
wait_timeout=3600
interactive_timeout=3600

#Query Cache
query_cache_type = 0
query_cache_size = 0

#Innodb
default_storage_engine = InnoDB
innodb_flush_log_at_trx_commit = 1
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1
innodb_autoinc_lock_mode = 2
innodb_buffer_pool_size = 8G
innodb_page_size = 16k
innodb_write_io_threads = 8
innodb_read_io_threads = 8
innodb_max_dirty_pages_pct = 50
innodb_print_all_deadlocks = 1

# 根据您的服务器IOPS能力适当调整
# 一般配普通SSD盘的话，可以调整到 10000 - 20000
# 配置高端PCIe SSD卡的话，则可以调整的更高，比如 50000 - 80000
innodb_io_capacity = 5000
innodb_io_capacity_max = 10000
innodb_flush_sync = 0
innodb_flush_neighbors = 0

#performance_schema
performance_schema = OFF
performance_schema_max_table_instances = 200

#Wsrep
wsrep_on = ON
wsrep_provider = /usr/lib/galera/libgalera_smm.so
wsrep_node_address = WSREP_NODE_ADDRESS
wsrep_sst_method = mariabackup
wsrep_sst_auth=safety:fakepassword
wsrep_sst_donor = WSREP_SST_DONOR
wsrep_gtid_mode = ON
wsrep_gtid_domain_id = 6

#Thread Pool
thread_handling=pool-of-threads
#thread_pool_max_threads=200
thread_pool_oversubscribe=3
extra_port=3310
extra_max_connections=8
!includedir /etc/mysql/mariadb.conf.d/

